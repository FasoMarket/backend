NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/fasomarket
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d

# Cloudinary (optionnel pour stockage cloud)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Limites
MAX_FILE_SIZE=5242880
MAX_FILES_PER_PRODUCT=5

# CORS - Pour le déploiement Railway
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,https://fasomarket-web.railway.app,https://fasomarket-admin.railway.app

# URLs pour la configuration mobile (optionnel, détecté automatiquement)
API_URL=https://fasomarket-backend.railway.app/api
SOCKET_URL=https://fasomarket-backend.railway.app

